{
  "name": "@logpose/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "build-catalog": "node scripts/build-catalog.mjs",
    "dev": "nest start --watch",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,html}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md,json,html}\"",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@jperezmart/nest-mongodb": "^0.1.0",
    "@logpose/contracts": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/terminus": "catalog:",
    "@orpc/contract": "catalog:",
    "@orpc/nest": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@logpose/eslint-config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}

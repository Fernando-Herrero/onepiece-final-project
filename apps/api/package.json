{
  "name": "@logpose/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/data dist/data",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,html}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md,json,html}\"",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@logpose/contracts": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@logpose/eslint-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}

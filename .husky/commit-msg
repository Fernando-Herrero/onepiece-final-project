#!/usr/bin/env sh

commit_msg_file="$1"

# Reject attribution trailers (do not silently strip — fail loud so it's obvious)
if grep -qiE 'Co-authored-by:.*([Cc]ursor|cursoragent@|Copilot|Claude|GPT|OpenAI|Anthropic)' "$commit_msg_file"; then
  echo '🚫 Commit rejected: Co-authored-by AI/Cursor attribution is not allowed.'
  exit 1
fi

if grep -qiE '^(Made-with: Cursor|Assisted-by:.*[Cc]ursor)' "$commit_msg_file"; then
  echo '🚫 Commit rejected: Cursor attribution trailers are not allowed.'
  exit 1
fi

if grep -qiE '(Made with (AI|Cursor)|generated by (AI|Cursor))' "$commit_msg_file"; then
  echo '🚫 Commit rejected: AI mentions are not allowed in commit messages.'
  exit 1
fi

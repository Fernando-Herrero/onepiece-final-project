#!/usr/bin/env sh

commit_msg_file="$1"

if grep -qiE '^(Co-authored-by:.*[Cc]ursor|Made-with: Cursor|Assisted-by:.*[Cc]ursor|Co-authored-by:.*cursoragent@)' "$commit_msg_file"; then
  echo '🚫 Commit rejected: AI/Cursor attribution trailers are not allowed.'
  exit 1
fi

if grep -qiE '(Co-authored-by:.*(Copilot|Claude|GPT|OpenAI|Anthropic)|Made with (AI|Cursor)|generated by (AI|Cursor))' "$commit_msg_file"; then
  echo '🚫 Commit rejected: AI mentions are not allowed in commit messages.'
  exit 1
fi

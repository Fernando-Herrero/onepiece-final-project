#!/usr/bin/env sh

commit_msg_file="$1"

if [ "$(uname)" = "Darwin" ]; then
  sed -i '' \
    -e '/^Co-authored-by: Cursor/d' \
    -e '/^Co-authored-by:.*cursoragent@/Id' \
    -e '/^Made-with: Cursor/d' \
    -e '/^Assisted-by:.*[Cc]ursor/d' \
    "$commit_msg_file"
else
  sed -i \
    -e '/^Co-authored-by: Cursor/d' \
    -e '/^Co-authored-by:.*cursoragent@/Id' \
    -e '/^Made-with: Cursor/d' \
    -e '/^Assisted-by:.*[Cc]ursor/d' \
    "$commit_msg_file"
fi

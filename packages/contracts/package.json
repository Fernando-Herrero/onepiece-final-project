{
  "name": "@logpose/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./contract": {
      "types": "./dist/contract.d.ts",
      "default": "./dist/contract.js"
    },
    "./implemented-contract": {
      "types": "./dist/implemented-contract.d.ts",
      "default": "./dist/implemented-contract.js"
    },
    "./features/*": {
      "types": "./dist/features/*.d.ts",
      "default": "./dist/features/*.js"
    },
    "./common/*": {
      "types": "./dist/common/*.d.ts",
      "default": "./dist/common/*.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch --preserveWatchOutput",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,html}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md,json,html}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@orpc/contract": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@logpose/eslint-config": "workspace:*",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
